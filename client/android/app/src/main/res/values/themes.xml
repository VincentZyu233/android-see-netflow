<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AndroidSeeNetflow" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/m3_primary</item>
        <item name="colorOnPrimary">@color/m3_on_primary</item>
        <item name="colorSurface">@color/m3_surface</item>
        <item name="colorSurfaceContainerHigh">@color/m3_surface_container_high</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/m3_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <style name="Widget.AndroidSeeNetflow.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.AndroidSeeNetflow.LargeField</item>
    </style>

    <style name="Widget.AndroidSeeNetflow.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/m3_primary</item>
        <item name="android:textColor">@color/m3_on_primary</item>
        <item name="cornerRadius">26dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="iconTint">@color/m3_on_primary</item>
    </style>

    <style name="Widget.AndroidSeeNetflow.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/m3_outline_variant</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="cornerRadius">26dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="iconTint">@android:color/black</item>
    </style>

    <style name="ShapeAppearanceOverlay.AndroidSeeNetflow.LargeField">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
</resources>
